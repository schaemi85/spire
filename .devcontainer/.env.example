# ==============================================================================
# Required - Git identity
# ==============================================================================
DEV_USER=<your-username>
DEV_EMAIL=<your-email>

# ==============================================================================
# Optional - Container registry (Docker Hub is used by default)
# ==============================================================================
# Override to pull the base Go image from a corporate registry.
# Examples:
#   BASE_IMAGE=artifactory.company.com/golang:1.26.0-bookworm
#   BASE_IMAGE=myregistry.azurecr.io/golang:1.26.0-bookworm
# BASE_IMAGE=golang:1.26.0-bookworm

# Registry to login to during setup (leave empty to skip docker login).
# DOCKER_REGISTRY=artifactory.company.com
# REGISTRY_TOKEN=<your-token>

# ==============================================================================
# Optional - Go module proxy / private modules
# ==============================================================================
# Default: public Go proxy. Set for corporate Artifactory / Athens / etc.
# GOPROXY=https://user:token@artifactory.company.com/artifactory/api/go/go-virtual
# GONOSUMDB=company.com
# GONOSUMCHECK=company.com

# ==============================================================================
# Optional - Upgrade tests (old spire binary)
# ==============================================================================
# Set both to install an older spire version as "old_spire" for upgrade tests.
# OLD_SPIRE_MODULE=github.com/your-org/spire
# OLD_SPIRE_VERSION=v1.4.0

# ==============================================================================
# Optional - Custom CA certificates
# ==============================================================================
# Place .crt or .pem files in .devcontainer/certs/ — they will be auto-installed
# into the container's trust store at build time.

# Add here your local secrets